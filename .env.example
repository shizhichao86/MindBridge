# =============================================================================
# MindBridge 配置文件模板
# 使用: cp .env.example .env  然后按需修改
# =============================================================================

# =============================================================================
# 1. AI 提供商(核心开关)
# =============================================================================
# 可选值: mock | ollama | openai
#   mock   = 模拟 AI,关键词驱动 canned 回复,无需 API Key/GPU(CI/开发用)
#   ollama = 本地 Ollama 微调模型(需先 ./scripts/start-ollama.sh)
#   openai = OpenAI 兼容 API(可用 OpenAI / DeepSeek / 阿里云百炼 / 硅基流动等)
AI_PROVIDER=mock

# LLM 推理参数(所有 AI_PROVIDER 共用)
AI_TEMPERATURE=0.35
AI_MAX_TOKENS=512

# =============================================================================
# 1a. OpenAI 兼容 API(当 AI_PROVIDER=openai 时生效)
# =============================================================================
# ---- DeepSeek(推荐:性价比高,开发测试首选) ----
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=你的DeepSeek_API_Key
# OPENAI_MODEL=deepseek-chat
# OPENAI_EMBEDDING_MODEL=                # DeepSeek 无 Embedding 模型,留空则自动退到 BM25

# ---- 阿里云百炼(通义千问) ----
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=你的阿里云百炼_API_Key
# OPENAI_MODEL=qwen-plus
# OPENAI_EMBEDDING_MODEL=text-embedding-v2

# ---- OpenAI 官方 ----
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- 其他兼容接口(硅基流动 / Together AI / 本地 vLLM 等) ----
# OPENAI_BASE_URL=你的API地址/v1
# OPENAI_API_KEY=你的Key
# OPENAI_MODEL=模型名

# 当前使用 Mock 模式,以下全部注释
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# 1b. 本地 Ollama(当 AI_PROVIDER=ollama 时生效)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mindbridge-qwen2.5-7b-ft:latest
# 微调模型关联(需先放好 GGUF 文件)
FINETUNED_MODEL_NAME=mindbridge-qwen2.5-7b-ft:latest
FINETUNED_MODEL_DIR=models/mindbridge-qwen2.5-7b-ft
FINETUNED_MODEL_FILE=mindbridge-qwen2.5-7b-ft-q4_k_m.gguf

# =============================================================================
# 2. Agent 运行时(多智能体协作参数)
# =============================================================================
# 当前只支持 event_driven_multi_agent,其他值会标记 fallback 但仍走事件驱动
AGENT_FRAMEWORK=event_driven_multi_agent

# 协调器预算: 最多 8 轮 / 每轮最多 4 个认领 / 每个 Agent 每会话最多 3 次认领
AGENT_MAX_ROUNDS=8
AGENT_MAX_CLAIMS_PER_ROUND=4
AGENT_MAX_CLAIMS_PER_AGENT=3
# 响应提案 + 安全审查通过 + 置信度 >= 0.6 时终态接受
AGENT_FINAL_ACCEPTANCE_MIN_CONFIDENCE=0.6

# 可选: 为每个 Agent 指定独立模型(provider/model/temperature/max_tokens)
# 不配则继承上方 AI_PROVIDER / OPENAI_MODEL 等默认值
# AGENT_MODEL_COORDINATOR_PROVIDER=
# AGENT_MODEL_COORDINATOR_MODEL=
# AGENT_MODEL_UNDERSTANDING_PROVIDER=
# AGENT_MODEL_UNDERSTANDING_MODEL=
# AGENT_MODEL_SAFETY_PROVIDER=
# AGENT_MODEL_SAFETY_MODEL=
# AGENT_MODEL_CONTEXT_PROVIDER=
# AGENT_MODEL_CONTEXT_MODEL=
# AGENT_MODEL_RESPONSE_PROVIDER=
# AGENT_MODEL_RESPONSE_MODEL=

# =============================================================================
# 3. 数据库与缓存
# =============================================================================
# MySQL(生产/完整开发), 也支持 SQLite(测试/Mock 模式)
# DATABASE_URL=mysql+pymysql://mindbridge:mindbridge@127.0.0.1:3306/mindbridge?charset=utf8mb4
DATABASE_URL=sqlite:///./data/mindbridge.db

# Redis(短期记忆 + Agent 私有记忆), 连不上不阻断聊天
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_MEMORY_TTL_SECONDS=86400          # 24 小时后自动过期
REDIS_MEMORY_MAX_MESSAGES=40            # 每会话最多保留条数
REDIS_SOCKET_TIMEOUT_SECONDS=2          # 连接超时

# =============================================================================
# 4. 记忆压缩
# =============================================================================
MEMORY_COMPACTION_ENABLED=true          # 是否启用以旧换新压缩
MEMORY_COMPACTION_RECENT_MESSAGES=8     # 最近保留条数(超出触发摘要压缩)
MEMORY_SUMMARY_MAX_CHARS=500            # memoryBrief 最大字符数

# =============================================================================
# 5. 知识库与 RAG
# =============================================================================
# 检索参数
KNOWLEDGE_TOP_K=4                       # 最终返回 chunk 数
KNOWLEDGE_CANDIDATE_K=16                # 每路候选数
KNOWLEDGE_CHUNK_SIZE=512                # 分块大小(字符)
KNOWLEDGE_CHUNK_OVERLAP=64              # 相邻 chunk 重叠量

# 混合检索权重
KNOWLEDGE_HYBRID_VECTOR_WEIGHT=0.65     # 向量权重
KNOWLEDGE_HYBRID_BM25_WEIGHT=0.35       # BM25 权重

# Reranker 开关
KNOWLEDGE_RERANK_ENABLED=true

# 向量检索开关(需 OPENAI_API_KEY + chromadb 包)
KNOWLEDGE_VECTOR_ENABLED=false           # true=启用 Chroma, false=纯 BM25
KNOWLEDGE_VECTOR_REQUIRED=false          # true=向量不可用时报错, false=自动降级
EMBEDDING_TIMEOUT_SECONDS=30

# Chroma 路径
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=mindbridge_knowledge
CHROMA_SNAPSHOT_DIR=data/chroma-snapshots
CHROMA_SNAPSHOT_KEEP=5                  # 快照最多保留份数

# =============================================================================
# 6. 工具队列(Excel 台账 / 案例创建 / 邮件预警)
# =============================================================================
TOOL_QUEUE_ENABLED=false                 # false=跳过队列(Mock模式/localhost)

# 队列参数(TOOL_QUEUE_ENABLED=true 时生效)
TOOL_QUEUE_POLL_INTERVAL_SECONDS=1      # 轮询间隔
TOOL_QUEUE_BATCH_SIZE=10                # 每次最多处理数
TOOL_QUEUE_MAX_ATTEMPTS=3               # 最大重试次数(超限入 dead_letter)
TOOL_QUEUE_RETRY_DELAY_SECONDS=15       # 重试延迟(指数退避基数)
TOOL_QUEUE_EXCEL_WORKERS=1              # Excel 写入线程数
TOOL_QUEUE_EMAIL_WORKERS=2              # 邮件发送线程数
ALERT_EMAIL_RATE_LIMIT_PER_MINUTE=30    # 邮件发送限流(每分钟)

# 告警发送模式: log=仅打日志(不真发) | smtp=真实发送(需配 SMTP)
ALERT_EMAIL_DELIVERY_MODE=log

# =============================================================================
# 7. 邮件提醒(SMTP — 仅 ALERT_EMAIL_DELIVERY_MODE=smtp 时生效)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_SUBJECT_PREFIX=[MindBridge 高风险预警]

# =============================================================================
# 8. 开发与评测
# =============================================================================
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# RAG 评测开关
RAG_EVAL_ENABLED=false
RAG_EVAL_EXIT_AFTER_RUN=false

# Excel 台账文件路径
EXCEL_PATH=data/mindbridge-risk-ledger.xlsx
